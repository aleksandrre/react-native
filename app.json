{
  "expo": {
    "name": "new",
    "slug": "new",
    "version": "1.0.2",
    "orientation": "portrait",
    "icon": "./assets/SplashScreen.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/SplashScreen.png",
      "resizeMode": "cover",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "ge.kustbapadel.app",
      "buildNumber": "1"
    },
    "android": {
      "versionCode": 4,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": false,
      "package": "ge.kustbapadel.app"
    },
    "androidNavigationBar": {
      "visible": "always",
      "backgroundColor": "#FFFFFF",
      "barStyle": "dark-content"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store"
    ],
    "extra": {
      "eas": {
        "projectId": "efe8d18e-aa5f-447d-8ac5-f6e2d5db8273"
      }
    }
  }
}